{
  "name": "cw-clicker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest -c vitest.config.js",
    "test:coverage": "vitest -c vitest.config.js --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky install"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "lucide-vue-next": "^1.0.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.27",
    "c8": "^11.0.0",
    "eslint": "^9.23.0",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^15.14.0",
    "husky": "^8.0.3",
    "lint-staged": "^13.2.1",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.19",
    "vite": "^6.2.2",
    "vitest": "^4.1.2"
  }
}
